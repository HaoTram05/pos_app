datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  OWNER
  MANAGER
  CASHIER
}

model Organization {
  id        String        @id @default(cuid())
  name      String
  subdomain String?       @unique
  logoUrl   String?
  currency  String        @default("VND")
  users     UserOrgRole[]
  products  Product[]
  customers Customer[]
  stores    Store[]
  sales     Sale[]
  createdAt DateTime      @default(now())
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  hashedPwd String
  fullName  String
  isActive  Boolean       @default(true)
  roles     UserOrgRole[]
  createdAt DateTime      @default(now())
  sales     Sale[]
}

model UserOrgRole {
  user   User         @relation(fields: [userId], references: [id])
  userId String
  org    Organization @relation(fields: [orgId], references: [id])
  orgId  String
  role   Role

  @@id([userId, orgId])
}

model Product {
  id        String       @id @default(cuid())
  org       Organization @relation(fields: [orgId], references: [id])
  orgId     String
  sku       String
  barcode   String?
  name      String
  unit      String       @default("cái")
  price     Decimal
  cost      Decimal      @default(0)
  taxRate   Decimal      @default(0)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())

  @@index([orgId, sku])
}

model Store {
  id      String       @id @default(cuid())
  org     Organization @relation(fields: [orgId], references: [id])
  orgId   String
  name    String
  address String?
  sales   Sale[]
}

model Sale {
  id         String       @id @default(cuid())
  org        Organization @relation(fields: [orgId], references: [id])
  orgId      String
  store      Store        @relation(fields: [storeId], references: [id])
  storeId    String
  cashier    User         @relation(fields: [cashierId], references: [id])
  cashierId  String
  total      Decimal
  discount   Decimal      @default(0)
  tax        Decimal      @default(0)
  grandTotal Decimal
  paid       Decimal
  change     Decimal      @default(0)
  status     String       @default("COMPLETED")
  createdAt  DateTime     @default(now())
}

model Customer {
  id        String       @id @default(cuid())
  org       Organization @relation(fields: [orgId], references: [id])
  orgId     String
  name      String
  phone     String?
  email     String?
  points    Int          @default(0)
  createdAt DateTime     @default(now())
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  orgId     String
  tokenHash String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
}
